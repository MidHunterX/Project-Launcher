    case "$project_type" in
        "none") ;;
        "angular") ;;
        "django") preflight_django ;;
        "elixir") ;;
        "flutter") ;;
        "go") ;;
        "gtk_astal") ;;
        "html") ;;
        "nextjs") ;;
        "nodejs") ;;
        "python") ;;
        "python_uv") ;;
        "python_fastapi") preflight_fastapi ;;
        "python_flask") ;;
        "reactjs") ;;
        "react_vite") ;;
        "rust") ;;
        *) ;;
    esac
}

