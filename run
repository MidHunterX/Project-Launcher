#!/usr/bin/env bash
# vim: filetype=bash
# DevNote: This script is kinda hard to re-write in a compiled language due to
# the way how a spawned process vs shell script modifies its environment. Using
# other forms of configs like yaml won't have the flexibility a shell script +
# source conf offers. Therefore bash is the best tool for this job of handling
# parent shell environment.

# -----------------------------[ CONFIGURATION ]----------------------------- #

config.clear() {
    # Default: project dir name
    PROJECT_NAME=""
    # Default: automatic detection
    # Available values:
    # none, angular, gtk_astal, django, elixir, python_fastapi, python_flask,
    # flutter, go, html, nextjs, nodejs, python, python_uv, reactjs,
    # react_vite, rust
    PROJECT_TYPE=""

    # Services: add any valid systemd services here
    ENABLED_SERVICES=(
        # postgresql
        # docker
        # mongod
        # nginx
    )

    # Default: automatic detection
    # Available values: none | {custom url}
    URL=""
    # Default: xdg-open
    # Available values: {custom command with arguments ending with newtab flag}
    BROWSER=""

    # Settings: [ true | false ]
    AUTORUN_COMMANDS=true
}

# =========================================================================== #

# █░█ ▀█▀ █ █░░ █▀
# █▄█ ░█░ █ █▄▄ ▄█

# log(str:message)
log() {
    local green='\033[1;32m'
    local reset='\033[0m'
    echo -e "[${green}$(date +'%H:%M:%S')${reset}] $1"
}

# code_block(str:message)
code_block() {
    local green='\033[1;32m'
    local bg_gray='\033[48;5;236m'
    local reset='\033[0m'
    local pad="  "
    # Read input (supports \n)
    local content
    content=$(printf "%b" "$1")
    # Split into lines
    IFS=$'\n' read -r -d '' -a lines <<<"$content"$'\0'
    # Calculate max line width
    local max=0
    for line in "${lines[@]}"; do
        ((${#line} > max)) && max=${#line}
    done
    local width=$((max + ${#pad} * 2))
    # Top padding
    echo ""
    printf "${bg_gray}${green}%*s${reset}\n" "$width" ""
    # Content
    for line in "${lines[@]}"; do
        printf "${bg_gray}${green}%s%-*s%s${reset}\n" \
            "$pad" "$max" "$line" "$pad"
    done
    # Bottom padding
    printf "${bg_gray}${green}%*s${reset}\n" "$width" ""
    echo ""
}

check_internet() {
    local host="${1:-1.1.1.1}"
    local timeout="${2:-3}"
    ping -c 1 -W "$timeout" "$host" >/dev/null 2>&1 && return 0
    return 1
}

# open_browser(str:new_tab_url str:browser_cmd?)
open_browser() {
    # CHECK: Valid URL
    local url="$1"
    if [[ -z "$url" ]]; then
        return
    fi

    # CHECK: Valid browser
    local browser="$2"
    if [[ -z "$browser" ]]; then
        browser="xdg-open"
    else
        command -v "${browser%% *}" >/dev/null || {
            log "❌ Error: ${browser%% *} not found"
            exit 1
        }
    fi

    log "🌐 Launching browser"
    (
        # Wait for the server to start
        local timeout=60
        while ! curl -sf "$url" >/dev/null; do
            sleep 1
            ((timeout--)) || { exit 1; }
        done

        # Launch the browser
        eval "$browser $url" >/dev/null &
    ) &
}

tmux_session_exists() {
    local name="$1"
    if tmux has-session -t "$name" 2>/dev/null; then
        return 0
    fi
    return 1
}

ensure_window() {
    local name="$1"
    if tmux_session_exists "$PROJECT_NAME"; then
        tmux new-window -t "$PROJECT_NAME" -n "$name"
    else
        tmux new-session -d -s "$PROJECT_NAME" -n "$name"
    fi
}

# create_window(window_name:str command?:str)
create_window() {
    local name="$1"
    local cmd="$2"

    # CHECK: Valid Name
    if [[ -z "$name" ]]; then
        log "🚫 Error: Missing window name"
        return
    fi

    # ACTION: Window without command
    if [[ -z "$cmd" ]]; then
        ensure_window "$name"
        return
    fi

    # ACTION: Create window only if valid command
    if command -v "${cmd%% *}" >/dev/null; then
        ensure_window "$name"

        local STRATEGY="clear" # clear | socket

        case "$STRATEGY" in
            clear)
                # "clear" Enter fixes send-keys doubling text due to shell race condition
                # Even though it's a hack, the logic is simple, it works and it's extremely fast
                tmux send-keys -t "$PROJECT_NAME:$name" "clear" Enter "$cmd"
                if [ "$AUTORUN_COMMANDS" == true ]; then
                    tmux send-keys -t "$PROJECT_NAME:$name" Enter
                fi
                ;;
            socket)
                # PHASE 1: Synchronize with shell readiness via wait-for
                local sync_channel="sync_${PROJECT_NAME}_${name}_$$_${RANDOM}"
                tmux wait-for -L "$sync_channel" # Lock
                tmux send-keys -t "$PROJECT_NAME:$name" "tmux wait-for -U $sync_channel" Enter
                tmux wait-for -L "$sync_channel"
                # PHASE 2: Shell is now ready. Send the actual command cleanly.
                tmux send-keys -t "$PROJECT_NAME:$name" "$cmd"
                if [ "$AUTORUN_COMMANDS" == true ]; then
                    tmux send-keys -t "$PROJECT_NAME:$name" Enter
                fi
                # PHASE 3: Unlock
                tmux wait-for -U "$sync_channel" 2>/dev/null || true
                ;;
        esac
    fi
}

# create_temp_window(str:window_name str:command)
create_temp_window() {
    local name="$1"
    local cmd="$2"
    if command -v "${cmd%% *}" >/dev/null; then
        tmux new-window -t "$PROJECT_NAME" -n "$name" "$cmd"
    fi
}

get_python_entrypoint() {
    for entry in "app/main.py" "main.py" "app.py" "server.py"; do
        if [[ -f "$entry" ]]; then
            echo "$entry"
            return 0
        fi
    done
    return 1
}

# █▄▄ █▀█ █▀█ █░█░█ █▀ █▀▀ █▀█
# █▄█ █▀▄ █▄█ ▀▄▀▄▀ ▄█ ██▄ █▀▄

get_server_url() {
    local project_type="$1"
    case "$project_type" in
        "none") ;; # Do nothing
        "angular") echo "http://localhost:4200" ;;
        "django") echo "http://localhost:8000" ;;
        "elixir") echo "http://localhost:4000" ;;
        "flutter") ;;
        "go") ;;
        "gtk_astal") ;;
        "html") command -v live-server >/dev/null && echo "http://localhost:8080" ;;
        "nextjs") echo "http://localhost:3000" ;;
        "nodejs") ;;
        "python") ;;
        "python_uv") ;;
        "python_fastapi") ;; # No need to open API url in browser
        "python_flask") echo "http://localhost:5000" ;;
        "reactjs") echo "http://localhost:3000" ;;
        "react_vite") echo "http://localhost:5173" ;;
        "rust") ;;
        *) log "🚧 Warning: No server url for ${project_type}" ;;
    esac
}

# █░░ ▄▀█ █▄█ █▀█ █░█ ▀█▀ █▀
# █▄▄ █▀█ ░█░ █▄█ █▄█ ░█░ ▄█

# run_server_command(str:project_type)
run_server_command() {
    local project_type="$1"
    case "$project_type" in
        "none") ;; # Do nothing
        "angular") echo "ng serve" ;;
        "django") echo "python manage.py runserver" ;;
        "elixir") echo "iex -S mix phx.server" ;;
        "flutter") echo "flutter run" ;;
        "go") echo "go run ." ;;
        "gtk_astal") echo "ags run" ;;
        "html") command -v live-server >/dev/null && echo "live-server --no-browser" ;;
        "nextjs") echo "npm run dev" ;;
        "nodejs") echo "npm start" ;;
        "python") echo "python $(get_python_entrypoint)" ;;
        "python_uv") echo "uv run $(get_python_entrypoint)" ;;
        "python_fastapi") echo "fastapi dev" ;; # uvicorn main:app --reload
        "python_flask") echo "python $(get_python_entrypoint)" ;;
        "reactjs") echo "npm start" ;;
        "react_vite") echo "npm run dev" ;;
        "rust") echo "cargo run" ;;
        *) log "🚧 Warning: No server setup for ${project_type}" ;;
    esac
}

setup_base_layout() {
    create_window "Cmd" "$(run_server_command "$PROJECT_TYPE")"
    [[ -n $EDITOR ]] && create_window "Editor" "$EDITOR"
}

setup_fastapi_layout() {
    setup_base_layout
    create_window "Test" "pytest"
}

setup_django_layout() {
    setup_base_layout
    create_window "Test" "python manage.py test"
}

setup_rust_layout() {
    setup_base_layout
    create_window "Test" "cargo test"
}

setup_go_layout() {
    setup_base_layout
    create_window "Test" "go test ./..."
}

setup_flutter_layout() {
    setup_base_layout
    create_window "Test" "flutter test"
}

# select_layout(str:project_type)
setup_layout() {
    local project_type="$1"
    case "$project_type" in
        "none") setup_base_layout ;;
        "angular") setup_base_layout ;;
        "django") setup_django_layout ;;
        "elixir") setup_base_layout ;;
        "flutter") setup_flutter_layout ;;
        "go") setup_go_layout ;;
        "gtk_astal") setup_base_layout ;;
        "html") setup_base_layout ;;
        "nextjs") setup_base_layout ;;
        "nodejs") setup_base_layout ;;
        "python") setup_base_layout ;;
        "python_uv") setup_base_layout ;;
        "python_fastapi") setup_fastapi_layout ;;
        "python_flask") setup_base_layout ;;
        "reactjs") setup_base_layout ;;
        "react_vite") setup_base_layout ;;
        "rust") setup_rust_layout ;;
        *)
            log "🚧 Unknown technology: ${project_type}. Using default layout."
            setup_base_layout
            ;;
    esac
}

