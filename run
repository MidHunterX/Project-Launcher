# █▀▄ █▀▀ ▀█▀ █▀▀ █▀▀ ▀█▀ █ █▀█ █▄░█
# █▄▀ ██▄ ░█░ ██▄ █▄▄ ░█░ █ █▄█ █░▀█

detect_project_type() {
    # python
    python_file=$(get_python_entrypoint)
    if [[ -f "$python_file" ]]; then
        if grep -q "from fastapi import FastAPI" "$python_file"; then
            echo "python_fastapi" && return
        elif grep -q "from flask import Flask" "$python_file"; then
            echo "python_flask" && return
        fi
        if [[ -f "uv.lock" ]]; then
            echo "python_uv" && return
        fi
        echo "python" && return
    fi

    # django
    if [[ -f "manage.py" ]]; then
        echo "django" && return
    fi

    # nodejs
    if [[ -f "package.json" ]]; then
        if [[ -f "angular.json" ]]; then
            echo "angular" && return
        elif [[ -f "next.config.js" ]] || [[ -f "next.config.ts" ]] || [[ -f "next.config.mjs" ]]; then
            echo "nextjs" && return
        elif [[ -f "vite.config.js" ]] || [[ -f "vite.config.ts" ]]; then
            echo "react_vite" && return
        elif grep -q "react" package.json; then
            echo "reactjs" && return
        elif [[ -d "@girs" ]]; then
            echo "gtk_astal" && return
        fi
        echo "nodejs" && return
    fi

    # flutter
    if [[ -f "pubspec.yaml" ]]; then
        echo "flutter" && return
    fi

    # elixir
    if [[ -f "mix.exs" ]]; then
        echo "elixir" && return
    fi

    # rust
    if [[ -f "Cargo.toml" ]]; then
        echo "rust" && return
    fi

    # go
    if [[ -f "go.mod" ]]; then
        echo "go" && return
    fi

    # html
    if [[ -f "index.html" ]]; then
        echo "html" && return
    fi

    # none
    echo "none" && return
}

# █▀▄▀█ ▄▀█ █ █▄░█
# █░▀░█ █▀█ █ █░▀█

config.load_user_overrides() {
    # INIT: Load global config if available
    config_file="${XDG_CONFIG_HOME:-$HOME/.config}/run/config.conf"
    # shellcheck disable=SC1090
    [[ -f "$config_file" ]] && source "$config_file"

    # INIT: Load custom overrides if available
    OVERRIDE_FILE=".runrc"
    # shellcheck disable=SC1090
    [[ -f "$OVERRIDE_FILE" ]] && source "$OVERRIDE_FILE"
}

config.detect_project_settings() {
    # FALLBACK: PROJECT_NAME={project dir name}
    if [[ -z "$PROJECT_NAME" ]]; then
        PROJECT_NAME="$(basename "$PWD")"
        # SANITIZE: Replace dots with underscores
        PROJECT_NAME="${PROJECT_NAME//./_}"
        # SANITIZE: Remove invalid characters
        PROJECT_NAME="${PROJECT_NAME//[^a-zA-Z0-9 _-]/}"
        # EDGE_CASE: No valid characters at all
        if [[ -z "$PROJECT_NAME" ]]; then
            PROJECT_NAME="invalid_project_name"
        fi
    fi

    # FALLBACK: PROJECT_TYPE={automatic detection}
    if [[ -z "$PROJECT_TYPE" ]]; then
        PROJECT_TYPE="$(detect_project_type)"
        log "🔍 Detected: $PROJECT_TYPE"
    fi

    # FALLBACK: NEW_TAB_URL={automatic detection}
    if [[ -z "$URL" ]]; then
        URL=$(get_server_url "$PROJECT_TYPE")
    fi
}

project.load_environment() {
    # SETUP: ENV or custom
    if declare -f setup_env_custom >/dev/null; then
        setup_env_custom
    else
        setup_env "$PROJECT_TYPE"
    fi
}

setup.code_output() {
    # ACTION: OPEN BROWSER
    if [[ "$URL" != "none" ]]; then
        open_browser "$URL" "$BROWSER"
    fi
}

setup.tmux_layout() {
    # REQUIRE: tmux dependency for LAYOUT
    if ! command -v tmux >/dev/null; then
        # FALLBACK: RUN SERVER (Blocking)
        local cmd
        cmd=$(run_server_command "$PROJECT_TYPE")
        if [[ -z "$cmd" ]]; then
            log "🚫 Error: No server found for this type"
            exit 1
        fi
        log "ℹ️ Running server without tmux"
        $cmd
        exit 0
    fi

    # ACTION: Attach session if exists
    if tmux has-session -t "$PROJECT_NAME" 2>/dev/null; then
        log "Session '$PROJECT_NAME' already exists"
        tmux attach -t "$PROJECT_NAME"
        exit 0
    fi

    # SETUP: LAYOUT or custom
    if declare -f setup_layout_custom >/dev/null; then
        setup_layout_custom
    else
        setup_layout "$PROJECT_TYPE"
    fi

    # ACTION: POST INIT HOOK
    if declare -f setup_post_init_hook >/dev/null; then
        setup_post_init_hook
    fi

    # Use "$PROJECT_NAME:1" to attach to the first window (server)
    # Use "$PROJECT_NAME" to see the test window in most projects
    # This is much better. You see breaking changes -> know what to fix next
    tmux attach -t "$PROJECT_NAME"
}

# =========================================================================== #

config.clear
config.load_user_overrides
config.detect_project_settings

project.load_environment
project.services.start

check.preflight "$PROJECT_TYPE"
setup.code_output
setup.tmux_layout
check.postflight "$PROJECT_TYPE"

# CASE: tmux session still exists / detached
if tmux_session_exists "$PROJECT_NAME"; then
    log "🌼 See you later!"
    exit 0
fi

project.services.stop
log "👋 Goodbye!"
